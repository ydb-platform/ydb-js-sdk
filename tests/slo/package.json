{
	"name": "@ydbjs/slo",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "bun run ./scripts/build.ts",
		"start:kv": "node --env-file=.env ./dist/index.js --setup=kv.setup --kv.setup.prefill=1000 --teardown=kv.teardown --worker=kv.read --kv.read.rps=1000 --kv.read.keyspace=1000 --worker=kv.write --kv.write.rps=100 --kv.write.keyspace=1000"
	},
	"dependencies": {
		"hdr-histogram-js": "3.0.1",
		"@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
		"@opentelemetry/sdk-metrics": "^2.7.0",
		"@ydbjs/api": "*",
		"@ydbjs/core": "*",
		"@ydbjs/query": "*",
		"@ydbjs/value": "*"
	},
	"overrides": {
		"@grpc/proto-loader": "npm:dry-uninstall"
	},
	"publishConfig": {
		"access": "restricted"
	}
}
