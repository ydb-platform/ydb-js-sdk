#!/usr/bin/env bash
set -euo pipefail

FILES=$(git diff --cached --name-only --diff-filter=ACMR | sed 's| |\\ |g')
[ -z "$FILES" ] && exit 0

# Lint staged files (oxlint has no stdin mode, so it works on the working tree)
echo "$FILES" | xargs ./node_modules/.bin/oxlint --fix --quiet
echo "$FILES" | xargs ./node_modules/.bin/oxfmt --no-error-on-unmatched-pattern
echo "$FILES" | xargs git add
