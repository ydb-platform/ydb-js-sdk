{
	"name": "@ydbjs/fsm",
	"version": "6.0.0",
	"description": "Lightweight async-first FSM runtime for YDB JavaScript SDK packages.",
	"keywords": [
		"ydb",
		"fsm",
		"state-machine",
		"async-iterable",
		"typescript"
	],
	"homepage": "https://github.com/ydb-platform/ydb-js-sdk/tree/main/packages/fsm#readme",
	"bugs": {
		"url": "https://github.com/ydb-platform/ydb-js-sdk/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ydb-platform/ydb-js-sdk.git",
		"directory": "packages/fsm"
	},
	"author": "YDB Team <team@ydb.tech> (https://ydb.tech)",
	"contributors": [
		"Vladislav Polyakov <me@polrk.com>"
	],
	"license": "Apache-2.0",
	"type": "module",
	"sideEffects": false,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./queue": "./dist/queue.js"
	},
	"engines": {
		"node": ">=20.19.0",
		"npm": ">=10"
	},
	"engineStrict": true,
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc -b tsconfig.build.json",
		"test": "tsc -b tsconfig.test.json && vitest --run",
		"attw": "attw --pack --profile esm-only"
	},
	"files": [
		"dist",
		"README.md",
		"DESIGN.md",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
