{
	"name": "@ydbjs/telemetry",
	"version": "6.0.0",
	"description": "Abstract telemetry interfaces and no-op implementation for YDB SDK. No OpenTelemetry dependency.",
	"keywords": [
		"ydb",
		"database",
		"telemetry",
		"tracing",
		"typescript"
	],
	"homepage": "https://github.com/ydb-platform/ydb-js-sdk#readme",
	"bugs": {
		"url": "https://github.com/ydb-platform/ydb-js-sdk/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ydb-platform/ydb-js-sdk.git",
		"directory": "packages/telemetry"
	},
	"author": "YDB Team <team@ydb.tech> (https://ydb.tech)",
	"license": "Apache-2.0",
	"type": "module",
	"sideEffects": false,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": "./dist/index.js"
	},
	"engines": {
		"node": ">=20.19.0",
		"npm": ">=10"
	},
	"engineStrict": true,
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc",
		"test": "vitest --run",
		"attw": "attw --pack --profile esm-only"
	},
	"dependencies": {
		"@ydbjs/api": "^6.0.0",
		"@ydbjs/error": "^6.0.0",
		"nice-grpc": "^2.1.13"
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md"
	],
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	}
}
