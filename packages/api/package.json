{
	"name": "@ydbjs/api",
	"version": "7.0.0",
	"description": "TypeScript gRPC service definitions and protobuf types for all YDB APIs. Enables strongly-typed client generation and low-level protocol access.",
	"keywords": [
		"api",
		"database",
		"grpc",
		"protobuf",
		"typescript",
		"ydb"
	],
	"homepage": "https://github.com/ydb-platform/ydb-js-sdk#readme",
	"bugs": {
		"url": "https://github.com/ydb-platform/ydb-js-sdk/issues"
	},
	"license": "Apache-2.0",
	"author": "YDB Team <team@ydb.tech> (https://ydb.tech)",
	"contributors": [
		"Vladislav Polyakov <me@polrk.com>"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ydb-platform/ydb-js-sdk.git",
		"directory": "packages/api"
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md"
	],
	"type": "module",
	"sideEffects": false,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		"./auth": {
			"development": "./src/auth.ts",
			"default": "./dist/auth.js"
		},
		"./bridge": {
			"development": "./src/bridge.ts",
			"default": "./dist/bridge.js"
		},
		"./cms": {
			"development": "./src/cms.ts",
			"default": "./dist/cms.js"
		},
		"./coordination": {
			"development": "./src/coordination.ts",
			"default": "./dist/coordination.js"
		},
		"./discovery": {
			"development": "./src/discovery.ts",
			"default": "./dist/discovery.js"
		},
		"./export": {
			"development": "./src/export.ts",
			"default": "./dist/export.js"
		},
		"./federation-discovery": {
			"development": "./src/federation_discovery.ts",
			"default": "./dist/federation_discovery.js"
		},
		"./import": {
			"development": "./src/import.ts",
			"default": "./dist/import.js"
		},
		"./monitoring": {
			"development": "./src/monitoring.ts",
			"default": "./dist/monitoring.js"
		},
		"./operation": {
			"development": "./src/operation.ts",
			"default": "./dist/operation.js"
		},
		"./query": {
			"development": "./src/query.ts",
			"default": "./dist/query.js"
		},
		"./rate-limiter": {
			"development": "./src/rate_limiter.ts",
			"default": "./dist/rate_limiter.js"
		},
		"./scheme": {
			"development": "./src/scheme.ts",
			"default": "./dist/scheme.js"
		},
		"./scripting": {
			"development": "./src/scripting.ts",
			"default": "./dist/scripting.js"
		},
		"./table": {
			"development": "./src/table.ts",
			"default": "./dist/table.js"
		},
		"./topic": {
			"development": "./src/topic.ts",
			"default": "./dist/topic.js"
		},
		"./value": {
			"development": "./src/value.ts",
			"default": "./dist/value.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"generate": "buf generate --template buf.gen.yaml && buf generate --template buf.gen.grpc.yaml",
		"clean": "rm -rf dist",
		"build": "tsc",
		"attw": "attw --pack --profile esm-only"
	},
	"dependencies": {
		"@bufbuild/protobuf": "2.12.0",
		"@grpc/grpc-js": "^1.14.0",
		"nice-grpc": "^2.1.13"
	},
	"devDependencies": {
		"@bufbuild/buf": "^1.61.0",
		"@bufbuild/protoc-gen-es": "^2.12.0",
		"typescript": "^6.0.3"
	},
	"engines": {
		"node": ">=20.19.0",
		"npm": ">=10"
	},
	"engineStrict": true
}
