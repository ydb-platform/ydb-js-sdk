{
	"name": "@ydbjs/value",
	"version": "6.0.9",
	"description": "Type-safe conversion and manipulation of YDB values and types. Encode/decode between native JS and YDB, with full support for primitives and complex types.",
	"keywords": [
		"conversion",
		"database",
		"types",
		"typescript",
		"value",
		"ydb"
	],
	"homepage": "https://github.com/ydb-platform/ydb-js-sdk#readme",
	"bugs": {
		"url": "https://github.com/ydb-platform/ydb-js-sdk/issues"
	},
	"license": "Apache-2.0",
	"author": "YDB Team <team@ydb.tech> (https://ydb.tech)",
	"contributors": [
		"Vladislav Polyakov <me@polrk.com>"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ydb-platform/ydb-js-sdk.git",
		"directory": "packages/value"
	},
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md"
	],
	"type": "module",
	"sideEffects": false,
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"development": "./src/index.ts",
			"default": "./dist/index.js"
		},
		"./primitive": {
			"development": "./src/primitive.ts",
			"default": "./dist/primitive.js"
		},
		"./optional": {
			"development": "./src/optional.ts",
			"default": "./dist/optional.js"
		},
		"./struct": {
			"development": "./src/struct.ts",
			"default": "./dist/struct.js"
		},
		"./dict": {
			"development": "./src/dict.ts",
			"default": "./dist/dict.js"
		},
		"./tuple": {
			"development": "./src/tuple.ts",
			"default": "./dist/tuple.js"
		},
		"./list": {
			"development": "./src/list.ts",
			"default": "./dist/list.js"
		},
		"./null": {
			"development": "./src/null.ts",
			"default": "./dist/null.js"
		},
		"./uuid": {
			"development": "./src/uuid.ts",
			"default": "./dist/uuid.js"
		},
		"./print": {
			"development": "./src/print.ts",
			"default": "./dist/print.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsc",
		"test": "vitest --run",
		"attw": "attw --pack --profile esm-only"
	},
	"dependencies": {
		"@bufbuild/protobuf": "2.12.0",
		"@date-fns/tz": "^1.4.1",
		"@ydbjs/api": "^7.0.0",
		"date-fns": "^4.1.0",
		"proposal-decimal": "^20250613.0.0"
	},
	"engines": {
		"node": ">=20.19.0",
		"npm": ">=10"
	},
	"engineStrict": true
}
