{
	"name": "ydbjs",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"docs",
		"e2e/*",
		"tests/*",
		"examples/*",
		"packages/*",
		"third-parties/*"
	],
	"engines": {
		"node": ">=20.19.0",
		"npm": ">=10"
	},
	"engineStrict": true,
	"scripts": {
		"build": "turbo run build --output-logs=errors-only",
		"attw": "turbo run attw",
		"test": "vitest --run",
		"coverage": "vitest --run --coverage",
		"lint": "oxlint --fix",
		"format": "oxfmt --write",
		"version": "npx changeset version && npm install",
		"publish": "npx changeset publish",
		"prepare": "git config core.hooksPath scripts/hooks"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "0.17.4",
		"@types/node": "^25.9.1",
		"@vitest/coverage-v8": "^5.0.0-beta.3",
		"@vitest/ui": "^5.0.0-beta.3",
		"fflate": "0.8.2",
		"oxfmt": "^0.52.0",
		"oxlint": "^1.66.0",
		"turbo": "^2.9.14",
		"typescript": "^6.0.3",
		"vitest": "^5.0.0-beta.3",
		"zx": "^8.8.5"
	},
	"overrides": {
		"@grpc/proto-loader": "npm:dry-uninstall",
		"esbuild": "^0.28.0",
		"fflate": "0.8.2",
		"protobufjs": "npm:dry-uninstall",
		"vite": "^8.0.0"
	},
	"packageManager": "npm@11.5.1"
}
